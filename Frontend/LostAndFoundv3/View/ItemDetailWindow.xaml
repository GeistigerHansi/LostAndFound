<Window x:Class="LostAndFound.WPF.View.ItemDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Height="460" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Titel -->
            <RowDefinition Height="Auto"/>  <!-- Beschreibung -->
            <RowDefinition Height="Auto"/>  <!-- Ort -->
            <RowDefinition Height="Auto"/>  <!-- Kategorie -->
            <RowDefinition Height="Auto"/>  <!-- Status -->
            <RowDefinition Height="Auto"/>  <!-- Funddatum -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Titel -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Titel *" VerticalAlignment="Center" Margin="0,8"/>
        <TextBox   Grid.Row="0" Grid.Column="1"
                   Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   Padding="6,4" Margin="0,8"/>

        <!-- Beschreibung -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Beschreibung" VerticalAlignment="Top" Margin="0,8"/>
        <TextBox   Grid.Row="1" Grid.Column="1"
                   Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                   Padding="6,4" Margin="0,8" VerticalScrollBarVisibility="Auto"/>

        <!-- Ort -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Fundort *" VerticalAlignment="Center" Margin="0,8"/>
        <TextBox   Grid.Row="2" Grid.Column="1"
                   Text="{Binding Location, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   Padding="6,4" Margin="0,8"/>

        <!-- Kategorie -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Kategorie" VerticalAlignment="Center" Margin="0,8"/>
        <ComboBox  Grid.Row="3" Grid.Column="1"
                   ItemsSource="{Binding Categories}"
                   SelectedItem="{Binding Category, Mode=TwoWay}"
                   Padding="6,4" Margin="0,8"/>

        <!-- Status -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Status" VerticalAlignment="Center" Margin="0,8"/>
        <ComboBox  Grid.Row="4" Grid.Column="1"
                   ItemsSource="{Binding Statuses}"
                   SelectedItem="{Binding Status, Mode=TwoWay}"
                   Padding="6,4" Margin="0,8"/>

        <!-- Funddatum -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Funddatum" VerticalAlignment="Center" Margin="0,8"/>
        <DatePicker Grid.Row="5" Grid.Column="1"
                    SelectedDate="{Binding FoundDate, Mode=TwoWay}"
                    Margin="0,8"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Grid.ColumnSpan="2" 
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Command="{Binding CancelCommand}"
                    Content="Abbrechen" Width="100" Padding="10,6" Margin="0,0,10,0"
                    Background="#EDF2F7" BorderBrush="#CBD5E0"/>
            <Button Command="{Binding SaveCommand}"
                    Content="💾 Speichern" Width="120" Padding="10,6"
                    Background="#4299E1" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
