<Window x:Class="LostAndFound.WPF.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LostAndFound.WPF.ViewModel"
        Title="Lost &amp; Found – Verwaltung" Height="620" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Status-Farben -->
        <Style x:Key="UnclaimedStyle" TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Unclaimed">
                    <Setter Property="Foreground" Value="#E53E3E"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Claimed">
                    <Setter Property="Foreground" Value="#38A169"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Archived">
                    <Setter Property="Foreground" Value="#718096"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar oben -->
        <ToolBar DockPanel.Dock="Top" Height="50" Background="#2D3748">
            <Button Command="{Binding AddItemCommand}" 
                    Margin="5,0" Padding="12,6" Background="#48BB78" Foreground="White"
                    BorderThickness="0" FontWeight="Bold">
                ➕ Neuer Gegenstand
            </Button>
            <Button Command="{Binding EditItemCommand}"
                    Margin="5,0" Padding="12,6" Background="#4299E1" Foreground="White"
                    BorderThickness="0" FontWeight="Bold">
                ✏️ Bearbeiten
            </Button>
            <Button Command="{Binding DeleteItemCommand}"
                    Margin="5,0" Padding="12,6" Background="#E53E3E" Foreground="White"
                    BorderThickness="0" FontWeight="Bold">
                🗑️ Löschen
            </Button>
            <Separator Margin="10,0"/>
            <Button Command="{Binding ShowClaimsCommand}"
                    Margin="5,0" Padding="12,6" Background="#ED8936" Foreground="White"
                    BorderThickness="0" FontWeight="Bold">
                📋 Ansprüche verwalten
            </Button>
            <Separator Margin="10,0"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="200" Margin="5,0" Padding="6,4"
                     VerticalContentAlignment="Center"/>
            <Button Command="{Binding SearchCommand}"
                    Margin="5,0" Padding="12,6" Background="#805AD5" Foreground="White"
                    BorderThickness="0">
                🔍 Suchen
            </Button>
            <Button Command="{Binding LoadItemsCommand}"
                    Margin="5,0" Padding="12,6" Background="#718096" Foreground="White"
                    BorderThickness="0">
                🔄 Aktualisieren
            </Button>
        </ToolBar>

        <!-- Statusleiste unten -->
        <StatusBar DockPanel.Dock="Bottom" Background="#EDF2F7">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#4A5568" FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Hauptinhalt: DataGrid -->
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Gefundene Gegenstände" 
                       FontSize="20" FontWeight="Bold" Foreground="#2D3748" Margin="0,0,0,10"/>

            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      AlternatingRowBackground="#F7FAFC"
                      RowBackground="White"
                      BorderBrush="#CBD5E0"
                      BorderThickness="1">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"       Binding="{Binding Id}"       Width="50"/>
                    <DataGridTextColumn Header="Titel"    Binding="{Binding Title}"     Width="*"/>
                    <DataGridTextColumn Header="Ort"      Binding="{Binding Location}"  Width="160"/>
                    <DataGridTextColumn Header="Kategorie" Binding="{Binding Category}" Width="110"/>
                    <DataGridTemplateColumn Header="Status" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Status}" Style="{StaticResource UnclaimedStyle}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Funddatum" 
                                        Binding="{Binding FoundDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                    <DataGridTextColumn Header="Ansprüche" 
                                        Binding="{Binding Claims.Count}"                Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>
</Window>
