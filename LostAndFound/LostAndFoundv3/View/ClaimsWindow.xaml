<Window x:Class="LostAndFound.WPF.View.ClaimsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ansprüche verwalten" Height="600" Width="900"
        WindowStartupLocation="CenterOwner">

    <DockPanel>
        <!-- Titel-Header -->
        <Border DockPanel.Dock="Top" Background="#2D3748" Padding="15,10">
            <TextBlock Text="{Binding ItemTitle}" FontSize="16" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Statusleiste -->
        <StatusBar DockPanel.Dock="Bottom" Background="#EDF2F7">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#4A5568" FontSize="12"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Inhalt: Links Liste, Rechts Formular -->
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Linke Seite: Liste der Claims -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Top" Text="Eingehende Ansprüche" 
                           FontSize="14" FontWeight="Bold" Margin="0,0,0,8" Foreground="#2D3748"/>

                <ListBox ItemsSource="{Binding Claims}"
                         SelectedItem="{Binding SelectedClaim}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" Margin="2">
                                <StackPanel>
                                    <TextBlock Text="{Binding ClaimantName}" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{Binding ClaimantContact}" Foreground="#718096" FontSize="11"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding ClaimDate, StringFormat=dd.MM.yyyy}" 
                                                   Foreground="#A0AEC0" FontSize="11"/>
                                        <TextBlock Text=" – " Foreground="#A0AEC0" FontSize="11"/>
                                        <TextBlock FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Ausstehend"/>
                                                    <Setter Property="Foreground" Value="#ED8936"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsApproved}" Value="True">
                                                            <Setter Property="Text" Value="✓ Genehmigt"/>
                                                            <Setter Property="Foreground" Value="#38A169"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#CBD5E0"/>

            <!-- Rechte Seite: Eingabeformular -->
            <DockPanel Grid.Column="2" Margin="10,0,0,0">
                <TextBlock DockPanel.Dock="Top" FontSize="14" FontWeight="Bold" 
                           Margin="0,0,0,12" Foreground="#2D3748">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Neuer Anspruch"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                    <Setter Property="Text" Value="Anspruch bearbeiten"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" 
                            HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Command="{Binding ClearFormCommand}"
                            Content="Neu / Leeren" Padding="10,6" Margin="0,0,6,0"
                            Background="#EDF2F7" BorderBrush="#CBD5E0"/>
                    <Button Command="{Binding DeleteClaimCommand}"
                            Content="🗑️ Löschen" Padding="10,6" Margin="0,0,6,0"
                            Background="#E53E3E" Foreground="White" BorderThickness="0"/>
                    <Button Command="{Binding AddClaimCommand}"
                            Content="➕ Hinzufügen" Padding="10,6" Margin="0,0,6,0"
                            Background="#48BB78" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                    <Button Command="{Binding SaveClaimCommand}"
                            Content="💾 Speichern" Padding="10,6"
                            Background="#4299E1" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
                </StackPanel>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock Text="Name *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ClaimantName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock Text="Kontakt (E-Mail/Tel.) *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ClaimantContact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,0,8">
                        <TextBlock Text="Begründung" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding ClaimDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                 Padding="6,4" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <CheckBox Grid.Row="3" 
                              IsChecked="{Binding IsApproved, Mode=TwoWay}"
                              Content="Anspruch genehmigen" Margin="0,4,0,0"
                              FontWeight="SemiBold" Foreground="#38A169"/>
                </Grid>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
